import java.util.Scanner;
public class great{
  public static void main(String args[]){
    scanner sc=new scanner(System.in);
    int a=sc.nextInt();
    int b=sc.nextInt();
    int c=sc.nextInt();
    
    if(a>b&&c)
    {
      System.out.println("a is greater"+a)
    }
    else if(b>a&&c)
    {
      System.out.println("b is greater"+b)
    }
    else
    { 
      System.out.println("c is greater"+c)
    }
  }
}
    